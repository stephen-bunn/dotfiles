# ----------------------
# wm independent hotkeys
# vim:ft=sxhkdrc
# ----------------------

# reload sxhkd and its confniguration files
super + Escape
    pkill -USR1 -x sxhkd

# pulseaudio controls
XF86AudioMute
    $HOME/.scripts/toggle-mute.sh

XF86AudioRaiseVolume
    $HOME/.scripts/raise-volume.sh

XF86AudioLowerVolume
    $HOME/.scripts/lower-volume.sh

XF86MonBrightnessUp
    $HOME/.scripts/raise-brightness.sh

XF86MonBrightnessDown
    $HOME/.scripts/lower-brightness.sh

XF86AudioMicMute
    $HOME/.scripts/toggle-mic.sh

XF86Favorites
    $HOME/.scripts/toggle-vpn.sh

